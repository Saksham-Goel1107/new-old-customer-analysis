# Separate .env for Total Customer Base Analysis
# Copy to .env.total and edit the values

# Google Sheets - input and output sheet IDs
TOTAL_INPUT_SHEET_ID=your-input-sheet-id-here
TOTAL_INPUT_SHEET_NAME=Sales Data
TOTAL_OUTPUT_SHEET_ID=your-output-sheet-id-here

# Path to credentials (mounted into container)
GOOGLE_CREDENTIALS_FILE=/app/credentials.json

# Run mode: 'scheduled' or 'once'
RUN_MODE=scheduled

# Heartbeat and retry settings (BetterStack)
HEARTBEAT_URL=https://uptime.betterstack.com/api/v1/heartbeat/aZ3cu9UpPN3fXD3ZeTbf3ZvF
RETRY_COUNT=3
RETRY_BACKOFF_SECONDS=30

# Timezone and logging
TZ=UTC
LOG_LEVEL=INFO

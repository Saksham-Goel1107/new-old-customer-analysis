# Google Sheets Configuration
# Get these IDs from the Google Sheets URLs
# Format: https://docs.google.com/spreadsheets/d/{SHEET_ID}/...

# The Google Sheet ID where sales data is stored
# This sheet should have columns: date, number, customerMobile, customerName, orderAmount
INPUT_SHEET_ID=your-input-sheet-id-here

# Optional: sheet tab name within the input Google Sheet (defaults to "Sales Data")
# Use this if your data is on a different tab (for example: main)
INPUT_SHEET_NAME=Sales Data

# The Google Sheet ID where results will be written
# Results will be in sheets: Counts Matrix, Retention % Matrix, Flat View, Summary
OUTPUT_SHEET_ID=your-output-sheet-id-here

# Google Credentials
# Path to your Service Account JSON file (downloaded from Google Cloud Console)
# In Docker we mount it at /app/credentials.json by default
GOOGLE_CREDENTIALS_FILE=/app/credentials.json

# Execution Mode
# 'scheduled' - Runs daily at 7:00 AM UTC
# 'once' - Runs immediately and exits
RUN_MODE=scheduled

# Heartbeat (BetterStack uptime monitor)
# Provide the full heartbeat URL; default points to your provided monitor
# The app will send a HEAD request to this URL on success.
# On failure it will append /fail or /<exit-code> as documented.
HEARTBEAT_URL=https://uptime.betterstack.com/api/v1/heartbeat/aZ3cu9UpPN3fXD3ZeTbf3ZvF

# Retry configuration for the analysis job (attempts and exponential backoff)
# Number of attempts total (first attempt + retries)
RETRY_COUNT=3
# Base backoff in seconds; each retry multiplies by 2^(attempt-1)
RETRY_BACKOFF_SECONDS=30

# Timezone (for logging/scheduler)
TZ=UTC

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
